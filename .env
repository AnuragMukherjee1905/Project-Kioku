# ============================================
# Project Kioku Backend — Environment Variables
# ============================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# MongoDB connection string
# Local:  mongodb://localhost:27017/projectkioku
# Atlas:  mongodb+srv://<user>:<pass>@cluster.mongodb.net/projectkioku
MONGO_URI=mongodb://localhost:27017/projectkioku

# JWT secret — use a long random string in production
JWT_SECRET=change_this_to_a_long_random_secret_string_12345

# JWT token expiry
JWT_EXPIRES_IN=7d

# Server port
PORT=5000

# Frontend origin for CORS (no trailing slash)
CLIENT_ORIGIN=http://127.0.0.1:5500
